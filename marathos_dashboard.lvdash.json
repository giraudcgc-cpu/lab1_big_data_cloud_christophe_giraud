    {
      "name": "54453406",
      "displayName": "speed_age_gender",
      "queryLines": [
        "SELECT *\r\n",
        "FROM marathos_cat.gold.mart_distance_by_age_gender\r\n",
        "WHERE age_bracket != 'Unknown'\r\n",
        "ORDER BY\r\n",
        "    CASE age_bracket\r\n",
        "        WHEN 'Under 30' THEN 1\r\n",
        "        WHEN '30-39' THEN 2\r\n",
        "        WHEN '40-49' THEN 3\r\n",
        "        WHEN '50-59' THEN 4\r\n",
        "        WHEN '60-69' THEN 5\r\n",
        "        WHEN '70-79' THEN 6\r\n",
        "        WHEN '80-89' THEN 7\r\n",
        "        WHEN '90-99' THEN 8\r\n",
        "        WHEN '100+' THEN 9\r\n",
        "    END"
      ]
    },
    {
      "name": "861ae4df",
      "displayName": "club_no_club",
      "queryLines": [
        "SELECT\r\n",
        "    runner_type,\r\n",
        "    SUM(total_races) AS total_races\r\n",
        "FROM marathos_cat.gold.mart_club_vs_norecordedclub_runners\r\n",
        "GROUP BY runner_type;"
      ]
    },
    {
      "name": "9f027c9f",
      "displayName": "top5_runners_duration",
      "queryLines": [
        "SELECT\r\n",
        "    rank,\r\n",
        "    run_distance_km,\r\n",
        "    avg_speed_kmh,\r\n",
        "    athlete_id,\r\n",
        "    athlete_gender,\r\n",
        "    athlete_country,\r\n",
        "    event_name\r\n",
        "FROM marathos_cat.gold.mart_top5_duration_event\r\n",
        "ORDER BY event_name, rank\r\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "a2b74a85",
      "displayName": "athlete_focus",
      "queryLines": [
        "-- Used LLM to help with a part of the code and with the age group ascending order\r\n",
        "\r\n",
        "SELECT *,\r\n",
        "    CASE age_bracket\r\n",
        "        WHEN '1. Under 30' THEN 1\r\n",
        "        WHEN '2. 30-39' THEN 2\r\n",
        "        WHEN '3. 40-49' THEN 3\r\n",
        "        WHEN '4. 50-59' THEN 4\r\n",
        "        WHEN '5. 60-69' THEN 5\r\n",
        "        WHEN '6. 70-79' THEN 6\r\n",
        "        WHEN '7. 80-89' THEN 7\r\n",
        "        WHEN '8. 90-99' THEN 8\r\n",
        "        WHEN '9. 100+' THEN 9\r\n",
        "    END AS age_sort\r\n",
        "FROM (\r\n",
        "    SELECT\r\n",
        "        f.athlete_id,\r\n",
        "        a.athlete_gender,\r\n",
        "        a.athlete_country,\r\n",
        "        CASE WHEN a.athlete_club IS NULL THEN 'No club recorded' ELSE 'Club member' END AS runner_type,\r\n",
        "        CASE \r\n",
        "            WHEN f.age_at_event IS NULL THEN 'Unknown'\r\n",
        "            WHEN f.age_at_event < 30 THEN '1. Under 30'\r\n",
        "            WHEN f.age_at_event < 40 THEN '2. 30-39'\r\n",
        "            WHEN f.age_at_event < 50 THEN '3. 40-49'\r\n",
        "            WHEN f.age_at_event < 60 THEN '4. 50-59'\r\n",
        "            WHEN f.age_at_event < 70 THEN '5. 60-69'\r\n",
        "            WHEN f.age_at_event < 80 THEN '6. 70-79'\r\n",
        "            WHEN f.age_at_event < 90 THEN '7. 80-89'\r\n",
        "            WHEN f.age_at_event < 100 THEN '8. 90-99'\r\n",
        "            ELSE '9. 100+'\r\n",
        "        END AS age_bracket,\r\n",
        "        e.event_type,\r\n",
        "        f.run_distance_km,\r\n",
        "        f.finish_time_hours,\r\n",
        "        f.athlete_average_speed\r\n",
        "    FROM marathos_cat.gold.fct_result f\r\n",
        "    LEFT JOIN marathos_cat.gold.dim_athlete a ON f.athlete_id = a.athlete_id\r\n",
        "    LEFT JOIN marathos_cat.gold.dim_event e ON f.event_id = e.event_id\r\n",
        "    WHERE f.athlete_average_speed IS NOT NULL\r\n",
        "        AND a.athlete_country IS NOT NULL\r\n",
        "        AND e.event_type IS NOT NULL\r\n",
        ") sub\r\n",
        "WHERE athlete_country IN (\r\n",
        "    SELECT athlete_country\r\n",
        "    FROM (\r\n",
        "        SELECT a.athlete_country, AVG(f.athlete_average_speed) AS avg_speed\r\n",
        "        FROM marathos_cat.gold.fct_result f\r\n",
        "        LEFT JOIN marathos_cat.gold.dim_athlete a ON f.athlete_id = a.athlete_id\r\n",
        "        WHERE f.athlete_average_speed IS NOT NULL\r\n",
        "            AND a.athlete_country IS NOT NULL\r\n",
        "        GROUP BY a.athlete_country\r\n",
        "        ORDER BY avg_speed DESC\r\n",
        "        LIMIT 10\r\n",
        "    )\r\n",
        ")\r\n",
        "ORDER BY age_sort"
      ]
    }
